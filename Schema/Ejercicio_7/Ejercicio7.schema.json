{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ejercicio 7",
  "description": "Tercer ejercicio de schemas con patrones",
  "type": "object",
  "properties": {
    "patrones": {
      "type": "object",
      "properties": {
        "numetoBinario": {
          "type": "string",
          "pattern": "^0b[01]+$"
        },
        "numeroOctal": {
          "type": "string",
          "pattern": "^0o[0-7]+$"
        },
        "numeroHexadecimal": {
          "type": "string",
          "pattern": "^0x[0-9a-fA-F]+$"
        },
        "sitemasOperativo": {
          "type": "string",
          "enum": ["Windows", "Linux", "macOS"]
        },
        "codigoDeBarras": {
          "type": "string",
          "pattern": "^\\d{1,2}-\\d{6}-\\d{6}$"
        },
        "direccionMemoria": {
          "type": "string",
          "pattern": "^0x[0-9a-fA-F]+$"
        },
        "direccionMAC": {
          "type": "string",
          "pattern": "^([0-9a-fA-F]{2}:){5}[0-9a-fA-F]{2}$"
        },
        "ipv6": {
          "type": "object",
          "properties": {
            "prefijo": {
              "type": "string",
              "pattern": "^([0-9a-fA-F]{1,4}:){7}[0-9a-fA-F]{1,4}$"
            },
            "id_subred": {
              "type": "string",
              "pattern": "^([0-9a-fA-F]{1,4}:){7}[0-9a-fA-F]{1,4}$"
            },
            "id_interfaz": {
              "type": "string",
              "pattern": "^([0-9a-fA-F]{1,4}:){7}[0-9a-fA-F]{1,4}$"
            }
          },
          "required": ["prefijo", "id_subred", "id_interfaz"],
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "patternProperties": {
    "^\\$": {}
  }
}
