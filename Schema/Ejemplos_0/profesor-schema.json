{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ejemplo Json Schema Profesor DAM",
  "description": "Este es el primer ejemplo para un objeto profesor en el curso de DAM",
  "type": "object",
  "properties": {
    "datospersonales": {
      "type": "object",
      "description": "Datos personales del profesor",
      "properties": {
        "nombre": {
          "type": "string",
          "description": "Nombre del profesor"
        },
        "edad": {
          "type": "integer",
          "description": "Edad del profesor",
          "minimum": 15,
          "maximum": 75
        }
      },
      "required": ["nombre", "edad"],
      "additionalProperties": false
    },
    "datosprofesionales": {
      "type": "object",
      "description": "Datos profesionales del profesor",
      "properties": {
        "departamento": {
          "type": "string",
          "description": "Departamento al que pertenece el profesor"
        },
        "asignaturas": {
          "type": "array",
          "description": "Asignaturas del profesor",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "uniqueItems": true,
          "maxItems": 5
        }
      },
      "required": ["departamento", "asignaturas"],
      "additionalProperties": false
    }
  },
  "required": ["datospersonales", "datosprofesionales"],
  "additionalProperties": {
    "^\\$": {}
  }
}
