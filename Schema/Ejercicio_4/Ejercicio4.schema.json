{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ejercicio4 Json Schema Profesor DAM",
  "description": "Este es el cuarto ejercicio en el curso de DAM",
  "type": "object",
  "properties": {
    "informacion_general": {
      "type": "object",
      "description": "Esquema para validar la información de un pedido",

      "properties": {
        "idPedido": {
          "type": "string",
          "maxLength": 7
        },

        "fecha": {
          "type": "string",
          "format": "date-time"
        },

        "cliente": {
          "type": "object",

          "properties": {
            "idCliente": {
              "type": "string"
            },

            "nombre": {
              "type": "string"
            },

            "telefono": {
              "type": "string"
            },

            "email": {
              "type": "string",
              "format": "email"
            },

            "direccion": {
              "type": "object",

              "properties": {
                "calle": {
                  "type": "string"
                },

                "ciudad": {
                  "type": "string"
                },

                "codigo_postal": {
                  "type": "string"
                },

                "pais": {
                  "type": "string"
                }
              },

              "required": ["calle", "ciudad", "codigo_postal", "pais"],

              "additionalProperties": false
            }
          },

          "required": ["idCliente", "nombre", "telefono", "email", "direccion"],

          "additionalProperties": false
        },

        "productos": {
          "type": "array",

          "items": {
            "type": "object",

            "properties": {
              "idProducto": {
                "type": "string"
              },

              "nombre": {
                "type": "string"
              },

              "cantidad": {
                "type": "integer",
                "minimum": 1
              },

              "precio_unitario": {
                "type": "number",
                "minimum": 0
              }
            },

            "required": ["idProducto", "nombre", "cantidad", "precio_unitario"],

            "additionalProperties": false
          }
        },

        "estado_pedido": {
          "type": "array",

          "items": {
            "type": "string"
          }
        },

        "total_pedido": {
          "type": "number",
          "minimum": 0
        }
      },

      "required": [
        "idPedido",
        "fecha",
        "cliente",
        "productos",
        "estado_pedido",
        "total_pedido"
      ],

      "additionalProperties": false
    }
  },

  "required": ["informacion_general"],

  "additionalProperties": false
}